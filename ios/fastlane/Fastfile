default_platform(:ios)

APP_SCHEME = "Playground"
XCODEPROJ = "Playground.xcodeproj"
APP_IDENTIFIER = ENV.fetch("APP_BUNDLE_ID", "io.github.imjasonh.playground")
KEYBOARD_IDENTIFIER = ENV.fetch("KEYBOARD_BUNDLE_ID", "io.github.imjasonh.playground.t9keyboard")
RIDE_WIDGET_IDENTIFIER = ENV.fetch("RIDE_WIDGET_BUNDLE_ID", "io.github.imjasonh.playground.ridemonitorwidget")
WATCH_IDENTIFIER = ENV.fetch("WATCH_BUNDLE_ID", "io.github.imjasonh.playground.watch")
# Host app + embedded extensions each need App Store profiles.
SIGNING_IDENTIFIERS = [
  APP_IDENTIFIER,
  KEYBOARD_IDENTIFIER,
  RIDE_WIDGET_IDENTIFIER,
  WATCH_IDENTIFIER
]

# Build an App Store Connect API token from the CI env. Shared by the lanes
# that talk to Apple.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_API_KEY_P8"),
    is_key_content_base64: true,
    in_house: false
  )
end

# Create Developer Portal Bundle IDs via the App Store Connect API when missing.
# Needed before `match` can mint profiles for extension targets (e.g. keyboard).
# In-app experiments do NOT need this — only Apple app-extension Bundle IDs.
def ensure_bundle_ids!(entries)
  require "spaceship"
  entries.each do |entry|
    identifier = entry.fetch(:id)
    name = entry.fetch(:name)
    existing = Spaceship::ConnectAPI::BundleId.find(identifier)
    if existing
      UI.success("Bundle ID '#{identifier}' already exists")
      next
    end
    UI.message("Creating Bundle ID '#{identifier}' (#{name})…")
    Spaceship::ConnectAPI::BundleId.create(
      name: name,
      identifier: identifier,
      platform: "IOS"
    )
    UI.success("Created Bundle ID '#{identifier}'")
  end
end

def profile_name_for(identifier)
  ENV["sigh_#{identifier}_appstore_profile-name"] || "match AppStore #{identifier}"
end

def apply_manual_signing!(team_id:, target:, profile_name:)
  update_code_signing_settings(
    path: XCODEPROJ,
    use_automatic_signing: false,
    team_id: team_id,
    code_sign_identity: "Apple Distribution",
    targets: [target],
    profile_name: profile_name
  )
end

platform :ios do
  desc "Run unit + UI tests on a simulator (no signing required)"
  lane :test do
    run_tests(
      project: XCODEPROJ,
      scheme: APP_SCHEME,
      # Device name is chosen at runtime by ios-ci.sh (falls back to a common
      # one) so we don't hardcode a simulator that a given Xcode may not ship.
      devices: [ENV.fetch("IOS_SIM_DEVICE", "iPhone 16")],
      result_bundle: true,
      output_directory: "fastlane/test_output"
    )
  end

  desc "One-time / when adding an Apple app extension: ensure Bundle IDs exist, " \
       "create distribution cert + App Store profiles, store them in match. " \
       "In-app experiments do NOT require re-running this."
  lane :signing_bootstrap do
    setup_ci # temporary CI keychain to hold the new certificate
    api_key = asc_api_key # also sets Spaceship::ConnectAPI.token

    # match cannot create a profile for a bundle id that does not exist on the
    # Developer Portal. `produce` does not support ASC API keys, so create any
    # missing Bundle IDs via Spaceship ConnectAPI first (idempotent).
    ensure_bundle_ids!(
      [
        { id: APP_IDENTIFIER, name: "ImJasonH Playground" },
        { id: KEYBOARD_IDENTIFIER, name: "Playground T9 Keyboard" },
        { id: RIDE_WIDGET_IDENTIFIER, name: "Playground Ride Monitor Widget" },
        { id: WATCH_IDENTIFIER, name: "Playground Ride Monitor Watch" }
      ]
    )

    match(
      type: "appstore",
      readonly: false, # create + push the signing assets
      app_identifier: SIGNING_IDENTIFIERS,
      api_key: api_key
    )
    # match only *warns* (doesn't fail) if it can't push to the git repo — e.g.
    # the token lacks write access — which would leave this lane falsely green
    # and the repo empty. Verify by re-fetching read-only: this clones the remote
    # fresh and fails if the assets never actually landed there.
    match(
      type: "appstore",
      readonly: true,
      app_identifier: SIGNING_IDENTIFIERS,
      api_key: api_key
    )
    UI.success("Signing assets created and verified in the match repo " \
               "(host app + T9 keyboard + Ride Monitor widget + Watch). " \
               "Future 'beta' runs will read them read-only. " \
               "Adding in-app experiments does not require re-running bootstrap.")
  end

  desc "Build a signed app-store IPA and upload it to TestFlight"
  lane :beta do
    setup_ci # creates a temporary CI keychain

    api_key = asc_api_key

    # Fetch certs + provisioning profiles from the private `match` repo, created
    # once by the `signing_bootstrap` lane; CI only reads them here.
    match(
      type: "appstore",
      readonly: true,
      app_identifier: SIGNING_IDENTIFIERS,
      api_key: api_key
    )

    # Pick a build number strictly greater than the newest one on TestFlight so
    # every upload is unique; fall back to the CI run number if the API lookup
    # fails (e.g. the very first upload before the app has any builds).
    build_number =
      begin
        latest_testflight_build_number(
          api_key: api_key,
          app_identifier: APP_IDENTIFIER
        ) + 1
      rescue StandardError
        Integer(ENV.fetch("GITHUB_RUN_NUMBER", "1"))
      end

    team_id = ENV.fetch("APPLE_TEAM_ID")
    # Use the exact profile name that match just installed rather than a
    # hardcoded guess: match appends a unique suffix when a base-named profile
    # already exists on the portal (e.g. left over from an earlier run), so the
    # real name may be "match AppStore <id> <digits>".
    app_profile = profile_name_for(APP_IDENTIFIER)
    keyboard_profile = profile_name_for(KEYBOARD_IDENTIFIER)
    widget_profile = profile_name_for(RIDE_WIDGET_IDENTIFIER)
    watch_profile = profile_name_for(WATCH_IDENTIFIER)

    # Each target has its own bundle ID / profile.
    apply_manual_signing!(team_id: team_id, target: "Playground", profile_name: app_profile)
    apply_manual_signing!(team_id: team_id, target: "T9Keyboard", profile_name: keyboard_profile)
    apply_manual_signing!(team_id: team_id, target: "RideMonitorWidget", profile_name: widget_profile)
    apply_manual_signing!(team_id: team_id, target: "RideMonitorWatch", profile_name: watch_profile)

    build_app(
      project: XCODEPROJ,
      scheme: APP_SCHEME,
      export_method: "app-store",
      # Force manual signing with the certificate + profile that `match`
      # installed, so the archive step doesn't try (and fail) to sign
      # automatically on a CI machine with no Apple account logged in.
      # Values containing spaces ("Apple Distribution", profile names) must be
      # quoted — xcargs is passed through a shell.
      xcargs: [
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "DEVELOPMENT_TEAM=#{team_id}",
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGN_IDENTITY='Apple Distribution'"
      ].join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          APP_IDENTIFIER => app_profile,
          KEYBOARD_IDENTIFIER => keyboard_profile,
          RIDE_WIDGET_IDENTIFIER => widget_profile,
          WATCH_IDENTIFIER => watch_profile
        }
      },
      output_directory: "fastlane/build"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      distribute_external: false, # internal testers only; no Beta App Review
      skip_waiting_for_build_processing: true
    )
  end
end
