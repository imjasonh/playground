default_platform(:ios)

APP_SCHEME = "HelloIOS"
XCODEPROJ = "HelloIOS.xcodeproj"
APP_IDENTIFIER = ENV.fetch("APP_BUNDLE_ID", "io.github.imjasonh.playground.helloios")

platform :ios do
  desc "Run unit + UI tests on a simulator (no signing required)"
  lane :test do
    run_tests(
      project: XCODEPROJ,
      scheme: APP_SCHEME,
      destination: "platform=iOS Simulator,name=iPhone 15,OS=latest",
      result_bundle: true,
      output_directory: "fastlane/test_output"
    )
  end

  desc "Build a signed app-store IPA and upload it to TestFlight"
  lane :beta do
    setup_ci # creates a temporary CI keychain

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_API_KEY_P8"),
      is_key_content_base64: true,
      in_house: false
    )

    # Fetch certs + provisioning profiles from the private `match` repo. Set up
    # once locally with `fastlane match appstore`; CI only reads them.
    match(
      type: "appstore",
      readonly: true,
      app_identifier: APP_IDENTIFIER,
      api_key: api_key
    )

    # Pick a build number strictly greater than the newest one on TestFlight so
    # every upload is unique; fall back to the CI run number if the API lookup
    # fails (e.g. the very first upload before the app has any builds).
    build_number =
      begin
        latest_testflight_build_number(
          api_key: api_key,
          app_identifier: APP_IDENTIFIER
        ) + 1
      rescue StandardError
        Integer(ENV.fetch("GITHUB_RUN_NUMBER", "1"))
      end

    build_app(
      project: XCODEPROJ,
      scheme: APP_SCHEME,
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      output_directory: "fastlane/build"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      distribute_external: false, # internal testers only; no Beta App Review
      skip_waiting_for_build_processing: true
    )
  end
end
